{
  "name": "html-to-docx-with-justjshtml",
  "version": "1.20.1",
  "description": "HTML to DOCX converter",
  "keywords": [
    "html-to-docx",
    "html to docx",
    "html",
    "docx",
    "office",
    "word",
    "pptx",
    "templates",
    "template",
    "templater",
    "templating",
    "report",
    "xlsx",
    "generation",
    "generate",
    "generator",
    "document generation",
    "document creator",
    "document automation",
    "dynamic document generation",
    "microsoft office",
    "microsoft word",
    "microsoft powerpoint",
    "microsoft excel",
    "create",
    "make",
    "Office Open XML",
    "OOXML",
    "document generation software",
    "automated document creation",
    "batch document generation",
    "document templating",
    "typescript",
    "ts",
    "hebrew",
    "arabic",
    "rtl",
    "right to left"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "browser": "dist/html-to-docx.browser.esm.js",
  "unpkg": "dist/html-to-docx.browser.js",
  "jsdelivr": "dist/html-to-docx.browser.js",
  "files": [
    "dist",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun run build && node tests/example-node.cjs",
    "test:comprehensive-svg": "bun run build && node tests/comprehensive-svg-test.js",
    "test:example-inline-svg": "bun run build && node tests/example-inline-svg.js",
    "test:rtl": "bun run build && node tests/example-rtl.js",
    "test:headings": "bun run build && node tests/example-heading-styles.cjs",
    "test:ts": "bun run build && cross-env TS_NODE_PROJECT=tests/examples/typescript/tsconfig.json ts-node -r tsconfig-paths/register tests/examples/typescript/typescript-example.ts",
    "test:ts-rtl": "bun run build && cross-env TS_NODE_PROJECT=tests/examples/typescript/tsconfig.json ts-node -r tsconfig-paths/register tests/examples/typescript/rtl-example.ts",
    "test:all": "bun run test:unit && bun run test && bun run test:headings && bun run test:ts && bun run test:ts-rtl",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:browser": "bun run build && npx -y serve . -l 8080 --no-clipboard",
    "prerelease": "bun run build:prod",
    "release": "standard-version",
    "lint": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "validate": "bun run lint && bun run format:check",
    "build": "tsdown",
    "build:dev": "NODE_ENV=development tsdown",
    "build:prod": "NODE_ENV=production tsdown",
    "diff:docx": "node scripts/diff-docx.js",
    "prepare": "husky install",
    "test:ts-example": "bun run build && cross-env TS_NODE_PROJECT=tests/examples/typescript/tsconfig.json ts-node -r tsconfig-paths/register tests/examples/typescript/typescript-example.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/turbodocx/html-to-docx.git"
  },
  "author": "TurboDocx, Inc.",
  "contributors": [
    "amrita-syn <amrita.yadav@synapsica.com>",
    "charuthaB <charutha.bhaskar@synapsica.com>",
    "hanagejet",
    "kurukururuu <apriansyah.fajar94@gmail.com>",
    "erenard",
    "KeithGillette",
    "juralio-james",
    "nicolasiscoding",
    "K-Kumar-01 ",
    "Swayamshu",
    "zedtux <zedtux@zedroot.org>",
    "hlerebours",
    "hakjeri",
    "tasola",
    "AmitSharma512",
    "AudunWA",
    "warlock7",
    "taro-shono",
    "braun1928",
    "juralio-james",
    "robinminso",
    "shareefalis",
    "adymo",
    "Srajan-Sanjay-Saxena",
    "jcasner",
    "demomacro",
    "29217321"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/TurboDocx/html-to-docx/issues"
  },
  "homepage": "https://github.com/TurboDocx/html-to-docx#readme",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "4.0.18",
    "cross-env": "10.1.0",
    "diff": "8.0.3",
    "husky": "9.1.7",
    "lint-staged": "16.3.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.23.0",
    "standard-version": "^9.3.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsdown": "^0.21.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "color-name": "2.1.0",
    "es-toolkit": "^1.45.1",
    "html-entities": "^2.3.3",
    "html-minifier-terser": "^7.2.0",
    "jszip": "^3.7.1",
    "justjshtml": "github:simonw/justjshtml#a415d0af40c34bf9a856e956d841513f482867e3",
    "lru-cache": "11.2.6",
    "nanoid": "5.1.6",
    "xmlbuilder2": "4.0.3"
  },
  "overrides": {
    "bl": "^1.2.3",
    "semver": "^7.6.0"
  },
  "resolutions": {
    "bl": "^1.2.3",
    "semver": "^7.6.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": [
      "oxfmt --write"
    ],
    "**/*.{ts,tsx,js,mjs,cjs}": [
      "oxlint --fix"
    ]
  }
}
