{
  "name": "html-to-docx-with-justjshtml",
  "version": "1.20.1",
  "description": "HTML to DOCX converter",
  "keywords": [
    "html-to-docx",
    "html to docx",
    "html",
    "docx",
    "office",
    "word",
    "pptx",
    "templates",
    "template",
    "templater",
    "templating",
    "report",
    "xlsx",
    "generation",
    "generate",
    "generator",
    "document generation",
    "document creator",
    "document automation",
    "dynamic document generation",
    "microsoft office",
    "microsoft word",
    "microsoft powerpoint",
    "microsoft excel",
    "create",
    "make",
    "Office Open XML",
    "OOXML",
    "document generation software",
    "automated document creation",
    "batch document generation",
    "document templating",
    "typescript",
    "ts",
    "hebrew",
    "arabic",
    "rtl",
    "right to left"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/browser.js",
  "types": "./dist/browser.d.ts",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser.d.ts",
        "import": "./dist/browser.js"
      },
      "node": {
        "types": "./dist/index.d.ts",
        "import": "./dist/node.js",
        "require": "./dist/node.cjs"
      },
      "default": {
        "types": "./dist/browser.d.ts",
        "import": "./dist/browser.js"
      }
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "default": "./dist/browser.js"
    },
    "./node": {
      "types": "./dist/index.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    }
  },
  "files": [
    "dist",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "test": "bun run build && node tests/example-node.cjs",
    "test:comprehensive-svg": "bun run build && node tests/comprehensive-svg-test.js",
    "test:example-inline-svg": "bun run build && node tests/example-inline-svg.js",
    "test:rtl": "bun run build && node tests/example-rtl.js",
    "test:headings": "bun run build && node tests/example-heading-styles.cjs",
    "test:baseline:node": "bun run build && node tests/regression-baseline/generate-baseline.cjs",
    "test:baseline:browser": "bun run build && node tests/regression-baseline/generate-baseline-browser.cjs",
    "test:ts": "bun run build && cross-env TS_NODE_PROJECT=tests/examples/typescript/tsconfig.json ts-node -r tsconfig-paths/register tests/examples/typescript/typescript-example.ts",
    "test:ts-rtl": "bun run build && cross-env TS_NODE_PROJECT=tests/examples/typescript/tsconfig.json ts-node -r tsconfig-paths/register tests/examples/typescript/rtl-example.ts",
    "test:prepare-artifacts": "node -e \"const fs=require('fs'); const path=require('path'); const tmp=path.resolve('tmp'); fs.mkdirSync(tmp,{recursive:true}); const stale=path.join(tmp,'example-node-browser.docx'); if (fs.existsSync(stale)) fs.rmSync(stale,{force:true});\"",
    "test:browser-images": "bun run build && node tests/example-browser-images.cjs",
    "test:all": "bun run test:prepare-artifacts && bun run test:unit:coverage && bun run test && bun run test:browser-images && bun run test:headings && bun run test:ts && bun run test:ts-rtl && bun run test:baseline:node && bun run test:baseline:browser && bun run api:check",
    "api:extract:browser": "api-extractor run --local --config config/api-extractor.browser.json",
    "api:extract:node": "api-extractor run --local --config config/api-extractor.node.json",
    "api:check": "bun run build && bun run api:extract:browser && bun run api:extract:node && node scripts/check-api-parity.cjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:browser": "bun run build && npx -y serve . -l 8080 --no-clipboard",
    "prerelease": "bun run build:prod",
    "release": "standard-version",
    "lint": "oxlint --fix --tsconfig tsconfig.build.json .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "validate": "bun run lint && bun run format:check",
    "build": "tsdown",
    "build:dev": "NODE_ENV=development tsdown",
    "build:prod": "NODE_ENV=production tsdown",
    "diff:docx": "node scripts/diff-docx.js",
    "prepare": "lefthook install",
    "test:ts-example": "bun run build && cross-env TS_NODE_PROJECT=tests/examples/typescript/tsconfig.json ts-node -r tsconfig-paths/register tests/examples/typescript/typescript-example.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/turbodocx/html-to-docx.git"
  },
  "author": "TurboDocx, Inc.",
  "contributors": [
    "amrita-syn <amrita.yadav@synapsica.com>",
    "charuthaB <charutha.bhaskar@synapsica.com>",
    "hanagejet",
    "kurukururuu <apriansyah.fajar94@gmail.com>",
    "erenard",
    "KeithGillette",
    "juralio-james",
    "nicolasiscoding",
    "K-Kumar-01 ",
    "Swayamshu",
    "zedtux <zedtux@zedroot.org>",
    "hlerebours",
    "hakjeri",
    "tasola",
    "AmitSharma512",
    "AudunWA",
    "warlock7",
    "taro-shono",
    "braun1928",
    "juralio-james",
    "robinminso",
    "shareefalis",
    "adymo",
    "Srajan-Sanjay-Saxena",
    "jcasner",
    "demomacro",
    "29217321"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/TurboDocx/html-to-docx/issues"
  },
  "homepage": "https://github.com/TurboDocx/html-to-docx#readme",
  "devDependencies": {
    "@microsoft/api-extractor": "^7.57.6",
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "4.0.18",
    "cross-env": "10.1.0",
    "diff": "8.0.3",
    "lefthook": "^1.11.13",
    "lint-staged": "16.3.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.23.0",
    "oxlint-tsgolint": "^0.23.0",
    "rollup": "^4.59.0",
    "rollup-plugin-cleaner": "^1.0.0",
    "rollup-plugin-node-builtins": "^2.1.2",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "@rollup/plugin-terser": "^1.0.0",
    "sharp": "^0.34.5",
    "standard-version": "^9.3.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsdown": "^0.21.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "color-name": "2.1.0",
    "es-toolkit": "^1.45.1",
    "html-entities": "^2.3.3",
    "jszip": "^3.7.1",
    "nanoid": "5.1.6",
    "xmlbuilder2": "4.0.3"
  },
  "overrides": {
    "bl": "^1.2.3",
    "semver": "^7.6.0"
  },
  "resolutions": {
    "bl": "^1.2.3",
    "semver": "^7.6.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": [
      "oxfmt --write"
    ],
    "**/*.{ts,tsx,js,mjs,cjs}": [
      "oxlint --fix --tsconfig=tsconfig.build.json"
    ]
  }
}
