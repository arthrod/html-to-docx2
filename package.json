{
  "name": "@turbodocx/html-to-docx",
  "version": "1.20.1",
  "description": "HTML to DOCX converter",
  "keywords": [
    "html-to-docx",
    "html to docx",
    "html",
    "docx",
    "office",
    "word",
    "pptx",
    "templates",
    "template",
    "templater",
    "templating",
    "report",
    "xlsx",
    "generation",
    "generate",
    "generator",
    "document generation",
    "document creator",
    "document automation",
    "dynamic document generation",
    "microsoft office",
    "microsoft word",
    "microsoft powerpoint",
    "microsoft excel",
    "create",
    "make",
    "Office Open XML",
    "OOXML",
    "document generation software",
    "automated document creation",
    "batch document generation",
    "document templating",
    "typescript",
    "ts",
    "hebrew",
    "arabic",
    "rtl",
    "right to left"
  ],
  "main": "dist/html-to-docx.umd.js",
  "module": "dist/html-to-docx.esm.js",
  "browser": "dist/html-to-docx.browser.esm.js",
  "unpkg": "dist/html-to-docx.browser.js",
  "jsdelivr": "dist/html-to-docx.browser.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/html-to-docx.esm.js",
      "require": "./dist/html-to-docx.umd.js",
      "default": "./dist/html-to-docx.esm.js"
    },
    "./browser": {
      "import": "./dist/html-to-docx.browser.esm.js",
      "default": "./dist/html-to-docx.browser.js"
    }
  },
  "types": "index.d.ts",
  "files": [
    "dist",
    "scripts/postinstall.js",
    "scripts/messages.json",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun run build && node example/example-node.js",
    "test:comprehensive-svg": "bun run build && node example/comprehensive-svg-test.js",
    "test:example-inline-svg": "bun run build && node example/example-inline-svg.js",
    "test:rtl": "bun run build && node example/example-rtl.js",
    "test:headings": "bun run build && node example/example-heading-styles.js",
    "test:ts": "bun run build && cross-env TS_NODE_PROJECT=example/typescript/tsconfig.json ts-node -r tsconfig-paths/register example/typescript/typescript-example.ts",
    "test:ts-rtl": "bun run build && cross-env TS_NODE_PROJECT=example/typescript/tsconfig.json ts-node -r tsconfig-paths/register example/typescript/rtl-example.ts",
    "test:all": "bun run test:unit && bun run test && bun run test:headings && bun run test:ts && bun run test:ts-rtl",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:vite:build": "bun run build && vite build --config vite.config.mjs",
    "test:vite:analyze:baseline": "bun run build && cross-env BUNDLE_ANALYZE=1 BUNDLE_ANALYZE_NAME=stats-baseline vite build --config vite.config.mjs",
    "test:vite:dev": "vite --config vite.config.mjs",
    "test:browser": "bun run build && npx -y serve . -l 8080 --no-clipboard",
    "prerelease": "bun run build:prod",
    "release": "standard-version",
    "lint": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "validate": "bun run lint && bun run format:check",
    "build": "rollup -c",
    "build:dev": "NODE_ENV=development rollup -c",
    "build:prod": "NODE_ENV=production rollup -c",
    "build:browser": "cross-env BUILD_TARGET=browser rollup -c",
    "build:browser:prod": "cross-env NODE_ENV=production BUILD_TARGET=browser rollup -c",
    "diff:docx": "node scripts/diff-docx.js",
    "prepare": "husky install",
    "postinstall": "node scripts/postinstall.js",
    "test:ts-example": "bun run build && cross-env TS_NODE_PROJECT=example/typescript/tsconfig.json ts-node -r tsconfig-paths/register example/typescript/typescript-example.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/turbodocx/html-to-docx.git"
  },
  "author": "TurboDocx, Inc.",
  "contributors": [
    "amrita-syn <amrita.yadav@synapsica.com>",
    "charuthaB <charutha.bhaskar@synapsica.com>",
    "hanagejet",
    "kurukururuu <apriansyah.fajar94@gmail.com>",
    "erenard",
    "KeithGillette",
    "juralio-james",
    "nicolasiscoding",
    "K-Kumar-01 ",
    "Swayamshu",
    "zedtux <zedtux@zedroot.org>",
    "hlerebours",
    "hakjeri",
    "tasola",
    "AmitSharma512",
    "AudunWA",
    "warlock7",
    "taro-shono",
    "braun1928",
    "juralio-james",
    "robinminso",
    "shareefalis",
    "adymo",
    "Srajan-Sanjay-Saxena",
    "jcasner",
    "demomacro",
    "29217321"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/TurboDocx/html-to-docx/issues"
  },
  "homepage": "https://github.com/TurboDocx/html-to-docx#readme",
  "devDependencies": {
    "@rollup/plugin-commonjs": "29.0.1",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@vitest/coverage-v8": "4.0.18",
    "cross-env": "10.1.0",
    "diff": "8.0.3",
    "husky": "9.1.7",
    "lint-staged": "16.3.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.23.0",
    "rollup": "4.59.0",
    "rollup-plugin-cleaner": "^1.0.0",
    "rollup-plugin-node-builtins": "^2.1.2",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "rollup-plugin-terser": "^7.0.2",
    "sharp": "^0.34.5",
    "standard-version": "^9.3.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-bundle-analyzer": "^1.3.6",
    "vite-plugin-console-pipe": "^2.1.0",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "axios": "^1.12.2",
    "color-name": "2.1.0",
    "es-toolkit": "^1.45.1",
    "html-entities": "^2.3.3",
    "html-minifier-terser": "^7.2.0",
    "htmlparser2": "^10.0.0",
    "jszip": "^3.7.1",
    "lru-cache": "11.2.6",
    "nanoid": "5.1.6",
    "xmlbuilder2": "4.0.3"
  },
  "overrides": {
    "bl": "^1.2.3",
    "semver": "^7.6.0"
  },
  "resolutions": {
    "bl": "^1.2.3",
    "semver": "^7.6.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": [
      "oxfmt --write"
    ],
    "**/*.{ts,tsx,js,mjs,cjs}": [
      "oxlint --fix"
    ]
  }
}
