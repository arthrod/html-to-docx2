{
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "sourceMap": true,
    "paths": {
      "@turbodocx/html-to-docx": ["../../"]
    }
  },
  "include": ["*.ts"],
  "exclude": ["node_modules"]
}
